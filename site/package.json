{
  "name": "@amsterdam-agent-skills/site",
  "version": "0.1.0",
  "description": "Astro showcase for the Amsterdam agent skill benchmarks. Reads benchmarks/benchmarks.json at build time and renders an interactive gallery of prototype iframes with an overlay toolbar.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run sync-prototypes && astro dev",
    "build": "bun run sync-prototypes && astro build",
    "preview": "astro preview --host localhost --port 4321",
    "typecheck": "astro check",
    "sync-prototypes": "bun run scripts/sync-prototypes.ts"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "packageManager": "bun@1.3.0",
  "dependencies": {
    "astro": "^5.14.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@types/bun": "latest",
    "@types/node": "^22.19.3",
    "typescript": "^5.9.3"
  }
}
